<component type="desktop-application">
  <id>io.github.saleguas.librewolfprofiles</id>
  <name>LibreWolf Profiles</name>
  <summary>Launch and manage LibreWolf profiles from one window</summary>
  <developer id="io.github.saleguas">
    <name>saleguas</name>
  </developer>
  <metadata_license>CC0-1.0</metadata_license>
  <!-- Replace this before submission once the project license is chosen. -->
  <project_license>LicenseRef-proprietary</project_license>
  <launchable type="desktop-id">io.github.saleguas.librewolfprofiles.desktop</launchable>

  <description>
    <p>LibreWolf must already be installed. The app auto-detects the LibreWolf Flatpak and profile registry, with Settings available for custom commands or profile locations.</p>
    <p>Use separate profiles for multiple Google accounts, workspaces, or browsing contexts while keeping LibreWolf's privacy-focused defaults.</p>
    <p>Launch, create, annotate, and open the default profile manager without editing profiles.ini by hand.</p>
  </description>

  <categories>
    <category>Network</category>
    <category>WebBrowser</category>
  </categories>

  <keywords>
    <keyword>LibreWolf</keyword>
    <keyword>Profile</keyword>
    <keyword>Browser</keyword>
    <keyword>Launcher</keyword>
  </keywords>

  <branding>
    <color type="primary" scheme_preference="light">#315f72</color>
    <color type="primary" scheme_preference="dark">#8ec5dd</color>
  </branding>

  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/saleguas/LibrewolfProfiles/main/docs/image.png</image>
      <caption>Review profiles, edit notes, and launch the selected profile</caption>
    </screenshot>
  </screenshots>

  <content_rating type="oars-1.1"/>

  <releases>
    <release version="0.1.0" date="2026-04-21"/>
  </releases>

  <url type="homepage">https://github.com/saleguas/LibrewolfProfiles</url>
  <url type="bugtracker">https://github.com/saleguas/LibrewolfProfiles/issues</url>
  <url type="vcs-browser">https://github.com/saleguas/LibrewolfProfiles</url>

  <requires>
    <control>keyboard</control>
    <control>pointing</control>
    <display_length compare="ge">768</display_length>
  </requires>
</component>
